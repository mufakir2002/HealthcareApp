<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <!-- Bottom nav destinations -->
    <fragment android:id="@+id/homeFragment"
        android:name="com.healthcare.portal.ui.home.HomeFragment"
        android:label="Home">
        <action android:id="@+id/action_home_to_track"
            app:destination="@id/trackFragment" />
        <action android:id="@+id/action_home_to_selectDept"
            app:destination="@id/homeFragment" />
        <action android:id="@+id/action_home_to_doctors"
            app:destination="@id/doctorsFragment" />
    </fragment>

    <fragment android:id="@+id/trackFragment"
        android:name="com.healthcare.portal.ui.track.TrackFragment"
        android:label="Track" />

    <fragment android:id="@+id/myAppointmentsFragment"
        android:name="com.healthcare.portal.ui.appointment.MyAppointmentsFragment"
        android:label="My Appointments" />

    <fragment android:id="@+id/profileFragment"
        android:name="com.healthcare.portal.ui.auth.ProfileFragment"
        android:label="Profile" />

    <!-- Booking flow -->
    <fragment android:id="@+id/doctorsFragment"
        android:name="com.healthcare.portal.ui.booking.DoctorsFragment"
        android:label="Choose Doctor">
        <argument android:name="departmentId"   app:argType="integer" />
        <argument android:name="departmentName" app:argType="string" />
        <action android:id="@+id/action_doctors_to_bookingForm"
            app:destination="@id/bookingFormFragment" />
    </fragment>

    <fragment android:id="@+id/bookingFormFragment"
        android:name="com.healthcare.portal.ui.booking.BookingFormFragment"
        android:label="Your Information">
        <action android:id="@+id/action_bookingForm_to_payment"
            app:destination="@id/paymentFragment" />
    </fragment>

    <fragment android:id="@+id/paymentFragment"
        android:name="com.healthcare.portal.ui.booking.PaymentFragment"
        android:label="Payment">
        <action android:id="@+id/action_payment_to_confirmation"
            app:destination="@id/confirmationFragment" />
        <argument android:name="appointmentId"     app:argType="integer" android:defaultValue="0" />
        <argument android:name="appointmentNumber" app:argType="string"  android:defaultValue="" />
    </fragment>

    <fragment android:id="@+id/confirmationFragment"
        android:name="com.healthcare.portal.ui.booking.ConfirmationFragment"
        android:label="Confirmed">
        <argument android:name="appointmentId"     app:argType="integer" />
        <argument android:name="appointmentNumber" app:argType="string" />
        <action android:id="@+id/action_confirmation_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true" />
        <action android:id="@+id/action_confirmation_to_track"
            app:destination="@id/trackFragment" />
    </fragment>

</navigation>
